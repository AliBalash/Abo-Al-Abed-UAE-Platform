{
  "name": "abo-al-abed-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @abo-al-abed/api prisma generate",
    "db:migrate": "pnpm --filter @abo-al-abed/api prisma migrate dev",
    "db:seed": "pnpm --filter @abo-al-abed/api prisma db seed",
    "ios:project": "cd apps/ios && xcodegen generate"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
